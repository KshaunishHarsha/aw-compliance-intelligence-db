# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/compliance_db
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/compliance_db

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-...

# Storage
STORAGE_PROVIDER=supabase
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1

# Storage — Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key   # use service role key, NOT the anon key
SUPABASE_BUCKET=documents

# App
ENVIRONMENT=development
SECRET_KEY=changeme-generate-a-real-secret-in-production
LOG_LEVEL=INFO
